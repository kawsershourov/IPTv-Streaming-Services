# --- Local secrets / config ---
/app/config.php

# --- Generated production build (regenerate with build-deploy.sh) ---
/ready-for-deploy/

# --- User uploads (keep folder structure, ignore uploaded files) ---
/uploads/logos/*
!/uploads/logos/.gitkeep
/uploads/media/*
!/uploads/media/.gitkeep

# --- GeoLite2 country database (MaxMind-licensed; uploaded via admin) ---
/app/data/*.mmdb

# --- Raw UVP plugin source & distributable zip (only /player subset is tracked) ---
/Ultimate Video Player v11.0 Latest Version/
/Ultimate Video Player v11.0 Latest Version.zip

# --- PHP / Composer ---
/vendor/
composer.lock

# --- Logs & temp ---
*.log
error_log
/tmp/
/cache/

